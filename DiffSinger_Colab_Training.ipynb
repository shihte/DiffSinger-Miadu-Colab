{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": { "id": "h1" },
      "source": [
        "# DiffSinger Miadu Fine-tuning (Colab 健壯版)\n",
        "**修復說明**：針對 Colab Python 3.12 環境優化了依賴安裝邏輯。"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": { "id": "c1" },
      "outputs": [],
      "source": [
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# 檢查 Drive 路徑 (如果不對請根據輸出調整後續指令)\n",
        "!ls \"/content/drive/MyDrive/\""
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": { "id": "c2" },
      "outputs": [],
      "source": [
        "%cd /content/\n",
        "!git clone https://github.com/shihte/DiffSinger-Miadu-Colab.git diffsinger-repo\n",
        "%cd diffsinger-repo\n",
        "\n",
        "# 分開安裝，確保即便某個失敗也不影響核心庫\n",
        "!pip install praat-parselmouth pyloudnorm webrtcvad pypinyin pycwt pyworld\n",
        "!pip install pytorch-lightning==1.6.5  # 使用更穩定的舊版 PL\n",
        "!pip install lightning-flash==0.7.0 --no-deps # 避免拉入 googleads 等衝突庫"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": { "id": "c3" },
      "outputs": [],
      "source": [
        "import os\n",
        "# 確保雲端路徑正確\n",
        "DRIVE_BASE = \"/content/drive/MyDrive/DiffSinger_Colab\"\n",
        "\n",
        "!mkdir -p checkpoints\n",
        "!mkdir -p data/binary\n",
        "\n",
        "if os.path.exists(DRIVE_BASE):\n",
        "    print(\"| 正在搬運權重與數據...\")\n",
        "    !cp -r \"{DRIVE_BASE}/1117_opencpop_ds1000_strict_pinyin\" checkpoints/ || echo \"基礎權重複製失敗\"\n",
        "    !cp -r \"{DRIVE_BASE}/nsf_hifigan_44.1k_hop512_128bin_2024.02\" checkpoints/ || echo \"聲碼器複製失敗\"\n",
        "    !cp -r \"{DRIVE_BASE}/miadu_finetune\" data/binary/ || echo \"數據複製失敗\"\n",
        "else:\n",
        "    print(f\"| 錯誤：找不到雲端路徑 {DRIVE_BASE}，請檢查 Drive 資料夾名稱！\")\n",
        "\n",
        "print(\"| 就緒！\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": { "id": "c4" },
      "outputs": [],
      "source": [
        "import os\n",
        "os.environ['PYTHONPATH'] = \".\"\n",
        "!python tasks/run.py --config usr/configs/midi/e2e/miadu_finetune.yaml --exp_name miadu_finetune_v1"
      ]
    }
  ],
